# ╔══════════════════════════════════════════════════════════════════╗
# ║              YouTube Shorts Factory — Environment               ║
# ╚══════════════════════════════════════════════════════════════════╝
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Gemini API Keys (rotational fallback chain) ──────────────────
# Ideally from DIFFERENT GCP projects for true quota isolation.
GEMINI_API_KEY_1=your_gemini_key_1
GEMINI_API_KEY_2=your_gemini_key_2
GEMINI_API_KEY_3=your_gemini_key_3
GEMINI_API_KEY_4=your_gemini_key_4

# ── Pexels API (free stock images for Story Engine) ──────────────
PEXELS_API_KEY=your_pexels_api_key

# ── ngrok Tunnel ─────────────────────────────────────────────────
NGROK_AUTHTOKEN=your_ngrok_authtoken
# Optional: set a static subdomain if you have a paid ngrok plan.
# Leave blank to use a random ephemeral URL.
NGROK_DOMAIN=

# ── Server ───────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Frontend Origin (for CORS) ───────────────────────────────────
# Comma-separated origins allowed to call this backend.
FRONTEND_ORIGINS=http://localhost:3000,https://your-app.vercel.app
